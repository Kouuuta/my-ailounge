# Supabase project URL — get from Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anonymous public key — safe for client-side use
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhb...

# Supabase service role key — keep secret, used only server-side for ingestion
SUPABASE_SERVICE_ROLE_KEY=eyJhb...

# GitHub personal access token — optional, ups Repo Radar API from 60 to 5k req/hr
# Generate at: https://github.com/settings/tokens (no special scopes needed)
# GH_ACCESS_TOKEN=ghp_abc123
